  comp 3: support_strut_left [union] box(length=15.0, width=10.0, height=40.0) — Vertical reinforcement pillar connecting tray underside to VESA plate on the right side
  comp 4: support_strut_right [union] box(length=15.0, width=10.0, height=40.0) — Vertical reinforcement pillar connecting tray underside to VESA plate on the left side
  comp 5: hex_airflow_cutouts [cut] custom(length=150.0, width=100.0, height=10.0) — Array of hexagonal voids in the tray center to reduce weight and allow laptop cooling
  comp 6: vesa_mounting_holes [cut] cylinder(diameter=5.5, height=12.0) — Four clearance holes for M4 screws matching VESA 100x100 standard
  comp 7: fillet_stress_junctions [fillet] custom(radius=3.0) — Radius fillets at strut-to-tray and strut-to-plate intersections to reduce stress concentration
